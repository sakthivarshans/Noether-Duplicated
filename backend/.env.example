# Google Genkit/Gemini API Key
GOOGLE_API_KEY="your_gemini_api_key_here"

# Firebase Admin SDK configuration (for JWT verification)
# Get these values from your Firebase project settings -> Service accounts
FIREBASE_PROJECT_ID="your_firebase_project_id"
FIREBASE_CLIENT_EMAIL="your_firebase_client_email"
FIREBASE_PRIVATE_KEY="your_firebase_private_key_in_quotes"

# Port for the server to run on (Render will set this automatically)
PORT=3001
