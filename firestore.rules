/**
 * @fileoverview Firestore Security Rules for the application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model. Users can only read and write data
 * associated with their own user ID.  Data validation is relaxed in this prototyping phase.
 *
 * Data Structure:
 * All data is nested under /users/{userId}, creating a clear ownership hierarchy.
 *
 * Key Security Decisions:
 * - Users can only list studySessions belonging to themselves.
 * - All subcollections under /users/{userId} follow the ownership model.
 *
 * Denormalization for Authorization:
 *  - The `userId` field is present in all subcollection documents. This avoids the need for
 *    costly `get()` calls to parent documents to verify ownership.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the request is authenticated.
     * @return {boolean} True if the request is authenticated, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user is the owner of the resource.
     * @param {string} userId The user ID to compare against the authenticated user's ID.
     * @return {boolean} True if the user is the owner, false otherwise.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user is the owner of the existing resource.
     * @param {string} userId The user ID to compare against the authenticated user's ID.
     * @return {boolean} True if the user is the owner and the resource exists, false otherwise.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * @description Rules for the /users/{userId} collection.
     * @path /users/{userId}
     * @allow (create) Authenticated user creates their own profile.
     * @allow (get) Authenticated user gets their profile.
     * @allow (update) Authenticated user updates their profile.
     * @allow (delete) Authenticated user deletes their profile.
     * @deny (create) If the user ID in the path does not match the authenticated user's ID.
     * @deny (update) If the user ID in the path does not match the authenticated user's ID.
     * @deny (delete) If the user ID in the path does not match the authenticated user's ID.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == request.auth.uid;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for the /users/{userId}/documents/{documentId} collection.
     * @path /users/{userId}/documents/{documentId}
     * @allow (create) Authenticated user creates a document under their profile.
     * @allow (get) Authenticated user gets a document under their profile.
     * @allow (update) Authenticated user updates a document under their profile.
     * @allow (delete) Authenticated user deletes a document under their profile.
     * @deny (create) If the user ID in the path does not match the authenticated user's ID.
     * @deny (update) If the user ID in the path does not match the authenticated user's ID.
     * @deny (delete) If the user ID in the path does not match the authenticated user's ID.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId}/documents/{documentId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for the /users/{userId}/documents/{documentId}/flashcards/{flashcardId} collection.
     * @path /users/{userId}/documents/{documentId}/flashcards/{flashcardId}
     * @allow (create) Authenticated user creates a flashcard under their document.
     * @allow (get) Authenticated user gets a flashcard under their document.
     * @allow (update) Authenticated user updates a flashcard under their document.
     * @allow (delete) Authenticated user deletes a flashcard under their document.
     * @deny (create) If the user ID in the path does not match the authenticated user's ID.
     * @deny (update) If the user ID in the path does not match the authenticated user's ID.
     * @deny (delete) If the user ID in the path does not match the authenticated user's ID.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId}/documents/{documentId}/flashcards/{flashcardId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for the /users/{userId}/pyqAnswers/{pyqAnswerId} collection.
     * @path /users/{userId}/pyqAnswers/{pyqAnswerId}
     * @allow (create) Authenticated user creates a PYQAnswer under their profile.
     * @allow (get) Authenticated user gets a PYQAnswer under their profile.
     * @allow (update) Authenticated user updates a PYQAnswer under their profile.
     * @allow (delete) Authenticated user deletes a PYQAnswer under their profile.
     * @deny (create) If the user ID in the path does not match the authenticated user's ID.
     * @deny (update) If the user ID in the path does not match the authenticated user's ID.
     * @deny (delete) If the user ID in the path does not match the authenticated user's ID.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId}/pyqAnswers/{pyqAnswerId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for the /users/{userId}/timetables/{timetableId} collection.
     * @path /users/{userId}/timetables/{timetableId}
     * @allow (create) Authenticated user creates a Timetable under their profile.
     * @allow (get) Authenticated user gets a Timetable under their profile.
     * @allow (update) Authenticated user updates a Timetable under their profile.
     * @allow (delete) Authenticated user deletes a Timetable under their profile.
     * @deny (create) If the user ID in the path does not match the authenticated user's ID.
     * @deny (update) If the user ID in the path does not match the authenticated user's ID.
     * @deny (delete) If the user ID in the path does not match the authenticated user's ID.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId}/timetables/{timetableId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for the /users/{userId}/todoTasks/{todoTaskId} collection.
     * @path /users/{userId}/todoTasks/{todoTaskId}
     * @allow (create) Authenticated user creates a TodoTask under their profile.
     * @allow (get) Authenticated user gets a TodoTask under their profile.
     * @allow (update) Authenticated user updates a TodoTask under their profile.
     * @allow (delete) Authenticated user deletes a TodoTask under their profile.
     * @deny (create) If the user ID in the path does not match the authenticated user's ID.
     * @deny (update) If the user ID in the path does not match the authenticated user's ID.
     * @deny (delete) If the user ID in the path does not match the authenticated user's ID.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId}/todoTasks/{todoTaskId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for the /users/{userId}/gameScores/{gameScoreId} collection.
     * @path /users/{userId}/gameScores/{gameScoreId}
     * @allow (create) Authenticated user creates a GameScore under their profile.
     * @allow (get) Authenticated user gets a GameScore under their profile.
     * @allow (update) Authenticated user updates a GameScore under their profile.
     * @allow (delete) Authenticated user deletes a GameScore under their profile.
     * @deny (create) If the user ID in the path does not match the authenticated user's ID.
     * @deny (update) If the user ID in the path does not match the authenticated user's ID.
     * @deny (delete) If the user ID in the path does not match the authenticated user's ID.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId}/gameScores/{gameScoreId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for the /users/{userId}/studySessions/{sessionId} collection.
     * @path /users/{userId}/studySessions/{sessionId}
     * @allow (create) Authenticated user creates a StudySession under their profile.
     * @allow (get) Authenticated user gets a StudySession under their profile.
     * @allow (list) Authenticated user lists StudySessions under their profile.
     * @allow (update) Authenticated user updates a StudySession under their profile.
     * @allow (delete) Authenticated user deletes a StudySession under their profile.
     * @deny (create) If the user ID in the path does not match the authenticated user's ID.
     * @deny (update) If the user ID in the path does not match the authenticated user's ID.
     * @deny (delete) If the user ID in the path does not match the authenticated user's ID.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId}/studySessions/{sessionId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }
  }
}