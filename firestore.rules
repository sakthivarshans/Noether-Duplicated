/**
 * @fileoverview Firestore Security Rules for the Noether application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for all data. Each user has complete control over their own data tree,
 * and no user can access or modify another user's data.
 *
 * Data Structure:
 * All data is nested under /users/{userId}, which creates a clear separation between users and their associated data.
 * This structure supports scalable authorization and simplifies security rules.
 *
 * Key Security Decisions:
 * - All data is private and user-specific. There are no shared or public collections.
 * - List operations are restricted to the owner of the data.
 * - All write operations (create, update, delete) are restricted to the owner of the data.
 *
 * Denormalization for Authorization:
 *  - The `userId` is included in every document to easily verify ownership.
 *  - The `userId` path parameter is matched against the `request.auth.uid` to ensure data consistency.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to determine if the request is made by a signed-in user.
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to determine if the request is made by the owner of the resource.
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Helper function to determine if the request is made by the existing owner of the resource.
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * @description Grants access to user profile data only to the authenticated user.
     * @path /users/{userId}
     * @allow (create) User with ID 'user123' can create their profile.
     *   request.auth.uid: 'user123'
     *   request.resource.data.id: 'user123'
     * @deny (create) User with ID 'user123' cannot create a profile with ID 'user456'.
     *   request.auth.uid: 'user123'
     *   request.resource.data.id: 'user456'
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Prevent listing of all users.

      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Grants access to documents only to the owner.
     * @path /users/{userId}/documents/{documentId}
     * @allow (create) User with ID 'user123' can create a document.
     *   request.auth.uid: 'user123'
     *   request.resource.data.userId: 'user123'
     * @deny (update) User with ID 'user123' cannot update a document owned by 'user456'.
     *   request.auth.uid: 'user123'
     *   resource.data.userId: 'user456'
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId}/documents/{documentId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Grants access to flashcards only to the owner.
     * @path /users/{userId}/documents/{documentId}/flashcards/{flashcardId}
     * @allow (create) User with ID 'user123' can create a flashcard.
     *   request.auth.uid: 'user123'
     *   request.resource.data.documentId: 'doc123'
     * @deny (update) User with ID 'user123' cannot update a flashcard owned by 'user456'.
     *   request.auth.uid: 'user123'
     *   resource.data.documentId: 'doc456'
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId}/documents/{documentId}/flashcards/{flashcardId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Grants access to past year questions only to the owner.
     * @path /users/{userId}/past_year_questions/{pastYearQuestionId}
     * @allow (create) User with ID 'user123' can create a past year question.
     *   request.auth.uid: 'user123'
     *   request.resource.data.userId: 'user123'
     * @deny (delete) User with ID 'user123' cannot delete a past year question owned by 'user456'.
     *   request.auth.uid: 'user123'
     *   resource.data.userId: 'user456'
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId}/past_year_questions/{pastYearQuestionId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Grants access to timetables only to the owner.
     * @path /users/{userId}/timetables/{timetableId}
     * @allow (create) User with ID 'user123' can create a timetable.
     *   request.auth.uid: 'user123'
     *   request.resource.data.userId: 'user123'
     * @deny (update) User with ID 'user123' cannot update a timetable owned by 'user456'.
     *   request.auth.uid: 'user123'
     *   resource.data.userId: 'user456'
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId}/timetables/{timetableId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Grants access to to-do tasks only to the owner.
     * @path /users/{userId}/todo_tasks/{todoTaskId}
     * @allow (create) User with ID 'user123' can create a to-do task.
     *   request.auth.uid: 'user123'
     *   request.resource.data.userId: 'user123'
     * @deny (delete) User with ID 'user123' cannot delete a to-do task owned by 'user456'.
     *   request.auth.uid: 'user123'
     *   resource.data.userId: 'user456'
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId}/todo_tasks/{todoTaskId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Grants access to voice notes only to the owner.
     * @path /users/{userId}/voice_notes/{voiceNoteId}
     * @allow (create) User with ID 'user123' can create a voice note.
     *   request.auth.uid: 'user123'
     *   request.resource.data.userId: 'user123'
     * @deny (update) User with ID 'user123' cannot update a voice note owned by 'user456'.
     *   request.auth.uid: 'user123'
     *   resource.data.userId: 'user456'
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId}/voice_notes/{voiceNoteId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Grants access to game scores only to the owner.
     * @path /users/{userId}/game_scores/{gameScoreId}
     * @allow (create) User with ID 'user123' can create a game score.
     *   request.auth.uid: 'user123'
     *   request.resource.data.userId: 'user123'
     * @deny (delete) User with ID 'user123' cannot delete a game score owned by 'user456'.
     *   request.auth.uid: 'user123'
     *   resource.data.userId: 'user456'
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId}/game_scores/{gameScoreId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }
  }
}