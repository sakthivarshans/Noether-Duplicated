/**
 * @fileoverview Firestore Security Rules for the application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model. Users can only read and write data
 * associated with their own user ID. This ensures data privacy and prevents unauthorized
 * access.
 *
 * Data Structure:
 * All data is nested under the /users/{userId} path, with subcollections for documents, flashcards,
 * PYQ answers, timetables, todo tasks, and game scores. This hierarchical structure simplifies
 * security rule definitions and enforces clear ownership.
 *
 * Key Security Decisions:
 * - User profiles are readable by anyone but only writable by the owner.
 * - All other collections are strictly owner-only for all operations.
 * - Listing operations are restricted to the owner for user-scoped collections to prevent
 *   unauthorized data discovery.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profile information. Users can only modify their own profile.
     * @path /users/{userId}
     * @allow (get, list): Any user can read a user profile.
     * @allow (create, update, delete): Only the user with the matching userId can modify their profile.
     * @deny Any other user attempting to modify another user's profile.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId} {
      allow get, list: if true;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to documents uploaded by the user. Only the owner can manage their documents.
     * @path /users/{userId}/documents/{documentId}
     * @allow (create, update, delete, get, list): Only the user with the matching userId can manage their documents.
     * @deny Any other user attempting to access another user's documents.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId}/documents/{documentId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to flashcards generated from a document. Only the owner of the document can manage the flashcards.
     * @path /users/{userId}/documents/{documentId}/flashcards/{flashcardId}
     * @allow (create, update, delete, get, list): Only the user with the matching userId can manage flashcards within their documents.
     * @deny Any other user attempting to access another user's flashcards.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId}/documents/{documentId}/flashcards/{flashcardId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.documentId == documentId;
      allow update: if isExistingOwner(userId) && request.resource.data.documentId == resource.data.documentId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to PYQ answers generated by the user. Only the owner can manage their PYQ answers.
     * @path /users/{userId}/pyqAnswers/{pyqAnswerId}
     * @allow (create, update, delete, get, list): Only the user with the matching userId can manage their PYQ answers.
     * @deny Any other user attempting to access another user's PYQ answers.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId}/pyqAnswers/{pyqAnswerId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to timetables generated by the user. Only the owner can manage their timetables.
     * @path /users/{userId}/timetables/{timetableId}
     * @allow (create, update, delete, get, list): Only the user with the matching userId can manage their timetables.
     * @deny Any other user attempting to access another user's timetables.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId}/timetables/{timetableId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to todo tasks created by the user. Only the owner can manage their todo tasks.
     * @path /users/{userId}/todoTasks/{todoTaskId}
     * @allow (create, update, delete, get, list): Only the user with the matching userId can manage their todo tasks.
     * @deny Any other user attempting to access another user's todo tasks.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId}/todoTasks/{todoTaskId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to game scores recorded by the user. Only the owner can manage their game scores.
     * @path /users/{userId}/gameScores/{gameScoreId}
     * @allow (create, update, delete, get, list): Only the user with the matching userId can manage their game scores.
     * @deny Any other user attempting to access another user's game scores.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId}/gameScores/{gameScoreId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == userId;
      allow delete: if isExistingOwner(userId);
    }

    // ---- Helper functions ----

    /**
     * @description Checks if the current user is signed in.
     * @return True if the user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the current user is the owner of the resource.
     * @param {string} userId The user ID to compare against the request's auth UID.
     * @return True if the user is the owner, false otherwise.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the current user is the owner of an existing resource.
     *              This function also verifies that the resource exists before granting access.
     * @param {string} userId The user ID to compare against the resource's owner ID.
     * @return True if the user is the owner and the resource exists, false otherwise.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }
  }
}